{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/token",
      "destination": "/api/main.py"
    },
    {
      "source": "/register",
      "destination": "/api/main.py"
    },
    {
      "source": "/posts",
      "destination": "/api/main.py"
    }
  ]
}