{
  "buildCommand": "npm run build",
  "outputDirectory": "./dist",
  "redirects": [
    {
      "source": "/api/:path*",
      "destination": "https://your-api-url.vercel.app/api/:path*"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": [
    "DATABASE_URL",
    "SUPABASE_URL",
    "SUPABASE_KEY",
    "SUPABASE_BUCKET_NAME",
    "SECRET_KEY",
    "ALGORITHM",
    "ACCESS_TOKEN_EXPIRE_MINUTES"
  ]
}
